{
    "app-id": "io.github.bazixv13.Hideaway",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "hideaway",
    "separate-locales": false,
    "cleanup": [
        "/share/doc",
        "/share/man",
        "/share/gtk-doc",
        "/include",
        "/lib/pkgconfig",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--filesystem=host-os",
        "--filesystem=~/.local/share/applications",
        "--filesystem=~/.local/share/flatpak",
        "--filesystem=/var/lib/flatpak",
        "--filesystem=~/.local/share/hideaway",
        "--filesystem=~/.local/share/icons:ro",
        "--filesystem=xdg-config/hideaway",
        "--talk-name=org.freedesktop.Flatpak",
        "--device=dri",
        "--env=GTK_A11Y=none"
    ],
    "modules": [
        {
            "name": "hideaway",
            "buildsystem": "meson",
            "build-options": {
                "env": {
                    "PYTHONOPTIMIZE": "2"
                }
            },
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/bazixv13/hideaway.git",
                    "tag": "v1.2.0"
                }
            ]
        }
    ]
}
