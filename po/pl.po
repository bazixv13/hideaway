msgid "Hideaway"
msgstr "Hideaway"

msgid "Search (Ctrl+F)"
msgstr "Szukaj (Ctrl+F)"

msgid "Search applications…"
msgstr "Szukaj aplikacji…"

msgid "Installed Applications"
msgstr "Zainstalowane aplikacje"

msgid "Manage applications shown in the GNOME overview."
msgstr "Zarządzaj aplikacjami wyświetlanymi w menu podglądu GNOME."

msgid "Preferences"
msgstr "Ustawienia"

msgid "Removal Behavior"
msgstr "Sposób usuwania"

msgid "Choose how applications are removed from the overview."
msgstr "Wybierz sposób usuwania aplikacji z menu aplikacji."

msgid "Use File Deletion"
msgstr "Usuwaj pliki"

msgid "Instead of hiding, move files to the backup directory. Requires root."
msgstr "Zamiast ukrywać, przenieś pliki do katalogu kopii zapasowej. Wymaga uprawnień roota."

msgid "Restore (Moved)"
msgstr "Przywróć (Przeniesione)"

msgid "Restore"
msgstr "Przywróć"

msgid "Remove"
msgstr "Usuń"

msgid "Invalid filename — operation aborted."
msgstr "Nieprawidłowa nazwa pliku — operacja przerwana."

msgid "Failed to hide app: {}"
msgstr "Nie udało się ukryć aplikacji: {}"

msgid "Failed to restore: {}"
msgstr "Nie udało się przywrócić: {}"

msgid "Authentication failed or was cancelled."
msgstr "Uwierzytelnianie nie powiodło się lub zostało anulowane."

msgid "Error moving file: {}"
msgstr "Błąd podczas przenoszenia pliku: {}"

msgid "Contributors"
msgstr "Współtwórcy"

msgid "Special Thanks"
msgstr "Specjalne podziękowania"

msgid "Change Icon"
msgstr "Zmień ikonę"

msgid "Change Application Icon"
msgstr "Zmień ikonę aplikacji"

msgid "Select a preset icon:"
msgstr "Wybierz gotową ikonę:"

msgid "Choose File…"
msgstr "Wybierz plik…"

msgid "Images (*.png, *.svg)"
msgstr "Obrazy (*.png, *.svg)"

msgid "Select Icon Image"
msgstr "Wybierz obraz ikony"

msgid "Reset to Default"
msgstr "Przywróć domyślną"

msgid "Cancel"
msgstr "Anuluj"

msgid "Apply"
msgstr "Zastosuj"
